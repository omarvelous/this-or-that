# Copy this file to .env.local and fill in the values.
# For local development, run `supabase start` and copy the values from its output.

# Supabase project URL
# Local:      http://localhost:54321
# Production: https://<project-id>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321

# Supabase anon (public) key — safe to expose in the browser
# Get from: `supabase start` output → "Publishable" key  (CLI v2.101+)
#           `supabase status`       → "Publishable" key
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key — NEVER expose this to the browser
# Get from: `supabase start` output → "Secret" key  (CLI v2.101+)
SUPABASE_SERVICE_ROLE_KEY=

# Public URL of this app (used for OG image generation and auth redirects)
# Local:      http://localhost:3000
# Production: https://your-domain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
